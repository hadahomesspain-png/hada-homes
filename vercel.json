{
  "version": 2,
  "crons": [
    {
      "path": "/api/ical-sync",
      "schedule": "0 6 * * *"
    }
  ],
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "hada-homes.com"
        }
      ],
      "destination": "https://hada.homes/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.hada-homes.com"
        }
      ],
      "destination": "https://hada.homes/$1",
      "permanent": true
    }
  ],
  "routes": [
    {
      "src": "/api/booking",
      "dest": "/api/booking.js"
    },
    {
      "src": "/api/create-checkout",
      "dest": "/api/create-checkout.js"
    },
    {
      "src": "/api/stripe-webhook",
      "dest": "/api/stripe-webhook.js"
    },
    {
      "src": "/api/ical-sync",
      "dest": "/api/ical-sync.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
